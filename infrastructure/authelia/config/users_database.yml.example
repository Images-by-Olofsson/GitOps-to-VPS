# Authelia Users Database Template
# =================================
# This file is NOT committed to Git.
# Copy to users_database.yml and use the Authelia hash generator:
#   docker run authelia/authelia:latest authelia crypto hash generate argon2
#
# Example entry:
# users:
#   yourusername:
#     displayname: "Your Name"
#     password: "$argon2id$v=19$m=65536,t=3,p=4$..."  # Generated hash
#     email: your-email@example.com
#     groups:
#       - admins

---
users:
  admin:
    displayname: "Admin"
    password: "GENERATE_HASH_WITH_AUTHELIA_CLI"
    email: admin@example.com
    groups:
      - admins
